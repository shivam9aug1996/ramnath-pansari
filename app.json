{
  "expo": {
    "name": "Ramnath Pansari",
    "slug": "ramnath-pansari-v1",
    "description": "Ramnath Pansari's app delivers groceries, herbal products, pooja items, wedding essentials, and chemicals quickly to your doorstep. It's your one-stop shop for daily and special needs, offering convenience and fast service.",
    "version": "1.0.30",
    "orientation": "portrait",
    "icon": "./assets/images/icon2.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#FFFFFF",
      "image": "./assets/images/splash2.png"
    },
    "newArchEnabled": true,
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/e4a21897-e720-4b3e-9bf0-c28832d5cdc7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ramnath.pansari.shop",
      "googleServicesFile": "./GoogleService-Info.plist",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive2.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.ramnath.pansari.shop",
      "versionCode": 25,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCY7OexW8I25uKjtJwqU1hAQZAZ4d8bnqQ"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "$(PRODUCT_NAME) uses your location to set delivery addresses on the map and show local weather near you. For example, when you save a home or work address, your coordinates place the map pin so we can route your grocery order to the correct doorstep.",
          "locationAlwaysAndWhenInUsePermission": "$(PRODUCT_NAME) uses your location to share live delivery progress with customers when you are an active delivery partner. For example, after you tap Start Delivery, your GPS updates on the map so the customer can track their order until it arrives.",
          "locationAlwaysPermission": "$(PRODUCT_NAME) uses your location in the background during active deliveries to share live driver position with customers. For example, while you navigate to the customer, your location updates on the order tracking map until the delivery is complete.",
          "isAndroidForegroundServiceEnabled": true,
          "isIosBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos",
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera"
        }
      ],
      [
        "expo-system-ui",
        {
          "edgeToEdge": true
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      "expo-image",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/splash2.png",
          "resizeMode": "contain",
          "imageWidth": 220
        }
      ],
      "expo-status-bar",
      [
        "expo-notifications",
        {
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://ramnath-pansari.vercel.app"
      },
      "eas": {
        "projectId": "e4a21897-e720-4b3e-9bf0-c28832d5cdc7"
      }
    },
    "owner": "shivam9aug1996",
    "runtimeVersion": "1.0.30"
  }
}
